    "clsx": "^2.1.1",
    "framer-motion": "^11.11.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.460.0",
    "minio": "^8.0.2",
    "next": "14.2.18",
    "next-auth": "^4.24.10",
    "nodemailer": "^6.9.16",
    "pdf-parse": "^1.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.2",
